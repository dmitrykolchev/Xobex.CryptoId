<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <RootNamespace>Xobex.CryptoId</RootNamespace>
    <IsPackable>true</IsPackable>
    <Title>Secure Database ID Obfuscation Library for ASP.NET Core</Title>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageId>Xobex.CryptoId.AspNetCore</PackageId>
  </PropertyGroup>

  <Import Project="..\Xobex.CryptoId.build.props" />

  <ItemGroup>
    <ProjectReference Include="..\Xobex.CryptoId\Xobex.CryptoId.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\LICENSE.txt">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
